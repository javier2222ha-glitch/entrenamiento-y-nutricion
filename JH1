<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Javier Hidalgo | Entrenamiento · Nutrición · Ciencias del Deporte</title>
<meta name="description" content="Asesorías personalizadas de entrenamiento y nutrición en Santiago de Chile. Planes individualizados basados en evidencia científica.">
<style>
:root{--b:#0a0a0a;--s:#111;--s2:#1a1a1a;--g:#c9a227;--g2:#e8d5a3;--w:#f5f5f5;--m:#888;--bd:rgba(255,255,255,.08);--tr:.35s cubic-bezier(.16,1,.3,1)}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}
body{background:var(--b);color:var(--w);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Inter,sans-serif;line-height:1.6;overflow-x:hidden}
img{max-width:100%;display:block}a{color:inherit;text-decoration:none}
::selection{background:var(--g);color:var(--b)}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--b)}::-webkit-scrollbar-thumb{background:var(--g);border-radius:2px}

/* Loader */
#ld{position:fixed;inset:0;z-index:9999;background:var(--b);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity .6s,visibility .6s}
#ld.g{opacity:0;visibility:hidden;pointer-events:none}
#ld .l{font-size:2rem;font-weight:900;letter-spacing:-2px}#ld .l span{color:var(--g)}
#ld .b{width:160px;height:2px;background:rgba(255,255,255,.1);border-radius:2px;overflow:hidden}
#ld .b i{display:block;height:100%;background:var(--g);width:0%;animation:lb 1.5s ease forwards}
@keyframes lb{0%{width:0%}50%{width:70%}100%{width:100%}}
#ld .n{font-size:.7rem;color:var(--m);letter-spacing:2px}

/* Header */
#hd{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 24px;transition:background .4s,backdrop-filter .4s,border-color .4s;border-bottom:1px solid transparent}
#hd.s{background:rgba(10,10,10,.95);backdrop-filter:blur(20px);border-color:var(--bd)}
#hd .in{display:flex;align-items:center;justify-content:space-between;height:64px;max-width:1200px;margin:0 auto}
#hd .lg{display:flex;align-items:center;gap:10px;font-weight:800;font-size:.95rem;letter-spacing:-.5px}
#hd .lg i{width:36px;height:36px;background:var(--g);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--b);font-style:normal;font-weight:900;font-size:1rem}
#hd .lg small{display:block;font-size:.6rem;color:var(--m);letter-spacing:1px;text-transform:uppercase;font-weight:500}
#hd nav{display:flex;align-items:center;gap:28px}
#hd nav a{font-size:.78rem;color:var(--m);text-transform:uppercase;letter-spacing:1px;font-weight:500;transition:color .2s;position:relative;padding-bottom:2px}
#hd nav a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--g);transition:width .3s var(--tr)}
#hd nav a:hover{color:var(--w)}#hd nav a:hover::after{width:100%}
#hd .wa{background:var(--g);color:var(--b);padding:9px 18px;border-radius:8px;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;transition:transform .2s,box-shadow .2s}
#hd .wa:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,162,39,.25)}
#hd .hm{display:none;flex-direction:column;gap:5px;padding:8px;background:none;border:none;cursor:pointer}
#hd .hm span{display:block;width:22px;height:1.5px;background:var(--w);transition:.3s}

/* Mobile nav */
#mn{position:fixed;inset:0;z-index:99;background:rgba(10,10,10,.98);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;opacity:0;visibility:hidden;transition:opacity .4s,visibility .4s}
#mn.o{opacity:1;visibility:visible}
#mn a{font-size:1.6rem;font-weight:800;color:var(--w);padding:12px 24px;border-radius:8px;transition:color .2s,background .2s}
#mn a:hover{color:var(--g);background:rgba(201,162,39,.08)}

/* Hero */
#he{position:relative;min-height:100vh;display:flex;align-items:center;padding:100px 24px 60px;overflow:hidden}
#he::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 50% at 70% 50%,rgba(201,162,39,.08),transparent);pointer-events:none}
#he .in{position:relative;z-index:2;max-width:1200px;margin:0 auto;width:100%}
#he .ey{display:flex;align-items:center;gap:12px;margin-bottom:24px;font-size:.7rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--g)}
#he .ey::before{content:'';width:30px;height:1px;background:var(--g)}
#he h1{font-size:clamp(2.5rem,6vw,5rem);font-weight:900;line-height:1.05;letter-spacing:-3px;margin-bottom:24px;max-width:650px}
#he h1 em{font-style:normal;color:var(--g);position:relative}
#he h1 em::after{content:'';position:absolute;bottom:4px;left:0;width:100%;height:8px;background:rgba(201,162,39,.15);z-index:-1}
#he p{color:var(--m);font-size:1.1rem;max-width:480px;line-height:1.7;margin-bottom:36px}
#he .ac{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:60px}
#he .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:10px;font-size:.85rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;transition:transform .2s,box-shadow .2s}
#he .btn:hover{transform:translateY(-3px)}
#he .btn-pr{background:var(--g);color:var(--b);box-shadow:0 12px 32px rgba(201,162,39,.2)}
#he .btn-gh{border:1px solid rgba(255,255,255,.15);color:var(--w)}
#he .btn-gh:hover{border-color:var(--g);color:var(--g)}
#he .st{display:flex;gap:10px;flex-wrap:wrap}
#he .st span{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.03);border:1px solid var(--bd);border-radius:99px;padding:10px 18px;font-size:.75rem;color:var(--m)}
#he .st span b{color:var(--g);font-weight:800;font-size:.9rem}

/* Scroll indicator */
#he .sc{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:.6}
#he .sc span{font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--m)}
#he .sc i{width:20px;height:32px;border:1.5px solid rgba(255,255,255,.2);border-radius:10px;display:flex;justify-content:center;padding-top:6px}
#he .sc i::after{content:'';width:3px;height:6px;background:var(--g);border-radius:2px;animation:sd 2s ease infinite}
@keyframes sd{0%,100%{transform:translateY(0);opacity:1}50%{transform:translateY(6px);opacity:.3}}

/* Marquee */
.mw{background:var(--g);overflow:hidden;padding:10px 0}
.mw .tr{display:flex;animation:mr 25s linear infinite;width:max-content}
.mw .tr:hover{animation-play-state:paused}
.mw span{display:inline-flex;align-items:center;gap:14px;padding:0 24px;font-size:.7rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--b);white-space:nowrap}
.mw span::after{content:'';width:4px;height:4px;border-radius:50%;background:rgba(0,0,0,.3)}
@keyframes mr{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* Sections */
.sc{padding:100px 24px}
.sc .in{max-width:1200px;margin:0 auto}
.sc .hd{text-align:center;margin-bottom:60px}
.sc .hd .tg{display:inline-flex;align-items:center;gap:6px;font-size:.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--g);border:1px solid rgba(201,162,39,.2);padding:5px 14px;border-radius:99px;margin-bottom:18px}
.sc .hd .tg::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--g)}
.sc .hd h2{font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:900;line-height:1.1;letter-spacing:-1.5px;margin-bottom:16px}
.sc .hd p{color:var(--m);font-size:1rem;max-width:520px;margin:0 auto;line-height:1.7}

/* Numbers */
#nu{padding:60px 24px;border-bottom:1px solid var(--bd)}
#nu .gr{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--bd);border-radius:16px;overflow:hidden}
#nu .ce{padding:36px 20px;text-align:center;border-right:1px solid var(--bd);transition:background .3s;position:relative}
#nu .ce:last-child{border-right:none}
#nu .ce::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--g);transform:scaleX(0);transition:transform .5s var(--tr)}
#nu .ce:hover{background:var(--s)}#nu .ce:hover::after{transform:scaleX(1)}
#nu .ce .vl{font-size:clamp(2rem,3.5vw,2.8rem);font-weight:900;color:var(--g);line-height:1;margin-bottom:6px}
#nu .ce .lb{font-size:.7rem;color:var(--m);letter-spacing:1.5px;text-transform:uppercase}

/* Services */
#sv .bn{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
#sv .ca{background:var(--s);border:1px solid var(--bd);border-radius:16px;padding:32px 28px;position:relative;transition:border-color .3s,transform .3s var(--tr)}
#sv .ca:hover{border-color:rgba(201,162,39,.2);transform:translateY(-5px)}
#sv .ca.f{grid-column:span 2;background:linear-gradient(135deg,#141200,#0d0c00);border-color:rgba(201,162,39,.12)}
#sv .ca .ic{width:44px;height:44px;border-radius:10px;background:rgba(201,162,39,.08);display:flex;align-items:center;justify-content:center;margin-bottom:18px;font-size:1.3rem;transition:transform .3s}
#sv .ca:hover .ic{transform:scale(1.1) rotate(-3deg)}
#sv .ca h3{font-size:1.05rem;font-weight:700;margin-bottom:8px}
#sv .ca p{font-size:.85rem;color:var(--m);line-height:1.6;margin-bottom:14px}
#sv .ca .tg{display:flex;flex-wrap:wrap;gap:5px}
#sv .ca .tg span{font-size:.65rem;font-weight:600;letter-spacing:.5px;text-transform:uppercase;padding:4px 10px;border-radius:99px;background:rgba(255,255,255,.04);border:1px solid var(--bd);color:#aaa}

/* Who */
#wh{background:var(--s)}
#wh .sp{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
#wh .im{position:relative}
#wh .fr{border-radius:16px;overflow:hidden;border:1px solid rgba(201,162,39,.15);background:var(--s2);aspect-ratio:3/4;position:relative}
#wh .fr img{width:100%;height:100%;object-fit:cover;filter:brightness(1.05)}
#wh .fr::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,transparent 50%,rgba(10,10,10,.7))}
#wh .cd{position:absolute;background:rgba(17,17,17,.95);border:1px solid rgba(201,162,39,.15);border-radius:12px;padding:14px 18px}
#wh .cd.c1{bottom:-12px;right:-12px}#wh .cd.c2{top:16px;left:-16px}
#wh .cd .n{font-size:1.3rem;font-weight:900;color:var(--g);line-height:1}
#wh .cd .l{font-size:.6rem;color:var(--m);letter-spacing:1px;text-transform:uppercase;margin-top:3px}
#wh .tx p{color:var(--m);line-height:1.7;margin-bottom:16px;font-size:.95rem}
#wh .vl{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:24px 0}
#wh .vl div{display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--s2);border:1px solid var(--bd);border-radius:8px;font-size:.82rem;color:#aaa;transition:border-color .2s,transform .2s}
#wh .vl div:hover{border-color:rgba(201,162,39,.2);transform:translateX(3px)}
#wh .cr{display:flex;flex-wrap:wrap;gap:6px}
#wh .cr span{font-size:.65rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:4px 10px;border-radius:99px;background:rgba(201,162,39,.06);border:1px solid rgba(201,162,39,.15);color:rgba(201,162,39,.7)}

/* Method */
#mt .st{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;position:relative}
#mt .st::before{content:'';position:absolute;top:28px;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(201,162,39,.2),transparent)}
#mt .st .st2{padding:0 10px;text-align:center;position:relative;z-index:1}
#mt .st .st2 .nm{width:56px;height:56px;border-radius:50%;background:var(--b);border:2px solid rgba(201,162,39,.2);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.1rem;font-weight:900;color:var(--g);transition:border-color .3s,background .3s}
#mt .st .st2:hover .nm{background:rgba(201,162,39,.08);border-color:var(--g)}
#mt .st .st2 h4{font-size:.9rem;font-weight:700;margin-bottom:6px}
#mt .st .st2 p{font-size:.8rem;color:var(--m);line-height:1.55}

/* Evaluation */
#ev{background:var(--s)}
#ev .sp{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start}
#ev .it{display:flex;flex-direction:column;gap:12px;margin:28px 0}
#ev .rw{display:flex;gap:14px;padding:16px 18px;background:var(--s2);border:1px solid var(--bd);border-radius:12px;transition:border-color .25s,transform .25s}
#ev .rw:hover{border-color:rgba(201,162,39,.2);transform:translateX(5px)}
#ev .rw .ic{width:36px;height:36px;border-radius:8px;background:rgba(201,162,39,.06);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
#ev .rw h4{font-size:.88rem;font-weight:700;margin-bottom:2px}
#ev .rw p{font-size:.78rem;color:var(--m)}
#ev .pn{background:var(--s2);border:1px solid rgba(201,162,39,.15);border-radius:16px;padding:28px}
#ev .pn h3{font-size:.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--g);margin-bottom:20px}
#ev .pn .rw2{display:flex;gap:12px;margin-bottom:16px}
#ev .pn .rw2 .ic2{font-size:1.3rem;width:28px}
#ev .pn .rw2 h4{font-size:.85rem;font-weight:700;margin-bottom:2px}
#ev .pn .rw2 p{font-size:.78rem;color:var(--m)}
#ev .gr2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:20px}
#ev .gr2 div{background:var(--b);border:1px solid var(--bd);border-radius:8px;padding:14px;text-align:center;transition:border-color .2s}
#ev .gr2 div:hover{border-color:rgba(201,162,39,.2)}
#ev .gr2 div .e{font-size:1.2rem;margin-bottom:3px}
#ev .gr2 div span{font-size:.6rem;color:var(--m);letter-spacing:1px;text-transform:uppercase}
#ev .wa{display:inline-flex;align-items:center;gap:8px;background:var(--g);color:var(--b);font-weight:700;font-size:.82rem;letter-spacing:1px;text-transform:uppercase;padding:14px 26px;border-radius:10px;transition:transform .2s,box-shadow .2s}
#ev .wa:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(201,162,39,.2)}

/* Sports */
#sp .gr{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-top:36px}
#sp .ch{display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border-radius:99px;background:var(--s);border:1px solid var(--bd);font-size:.82rem;font-weight:600;color:#aaa;transition:border-color .2s,background .2s,transform .2s}
#sp .ch:hover{border-color:var(--g);background:rgba(201,162,39,.06);color:var(--w);transform:scale(1.05)}

/* Plans */
#pl .gr{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;align-items:start}
#pl .pn{background:var(--s);border:1px solid var(--bd);border-radius:16px;padding:28px 22px;position:relative;transition:border-color .3s,transform .3s}
#pl .pn:hover:not(.f){transform:translateY(-4px);border-color:rgba(201,162,39,.15)}
#pl .pn.f{background:linear-gradient(160deg,#1a1700,#0f0d00);border-color:var(--g);transform:scale(1.02);box-shadow:0 0 50px rgba(201,162,39,.08)}
#pl .pn .bd{position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:var(--g);color:var(--b);font-size:.6rem;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:3px 12px;border-radius:99px}
#pl .pn .nm{font-size:.72rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--m);margin-bottom:4px}
#pl .pn .pr{font-size:2rem;font-weight:900;line-height:1;margin-bottom:4px}
#pl .pn .nt{font-size:.75rem;color:var(--m);margin-bottom:18px}
#pl .pn .dv{height:1px;background:var(--bd);margin:14px 0}
#pl .pn ul{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:22px}
#pl .pn ul li{display:flex;align-items:flex-start;gap:8px;font-size:.8rem;color:#bbb}
#pl .pn ul li::before{content:'✓';color:var(--g);font-weight:800;flex-shrink:0}
#pl .pn .bt{display:block;text-align:center;padding:12px;border-radius:8px;font-weight:700;font-size:.78rem;letter-spacing:1px;text-transform:uppercase;transition:all .2s}
#pl .pn .bt.ol{border:1px solid rgba(255,255,255,.12);color:var(--w)}
#pl .pn .bt.ol:hover{border-color:var(--g);color:var(--g)}
#pl .pn .bt.sl{background:var(--g);color:var(--b)}
#pl .pn .bt.sl:hover{background:#e8d5a3;transform:translateY(-2px)}

/* Blog */
#bl{background:var(--s)}
#bl .gr{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px}
#bl .ca{background:var(--s2);border:1px solid var(--bd);border-radius:16px;overflow:hidden;transition:border-color .3s,transform .3s,box-shadow .3s;cursor:pointer}
#bl .ca:hover{border-color:rgba(201,162,39,.2);transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,.4)}
#bl .ca .im{height:180px;background:linear-gradient(135deg,#1a1a1a,#0f0f0f);display:flex;align-items:center;justify-content:center;font-size:3rem;position:relative;overflow:hidden}
#bl .ca .im::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(17,17,17,.8),transparent)}
#bl .ca:hover .im::before{content:'';position:absolute;inset:0;background:rgba(201,162,39,.05)}
#bl .ca .bd{padding:24px}
#bl .ca .ct{font-size:.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--g);margin-bottom:8px}
#bl .ca h3{font-size:1.05rem;font-weight:800;line-height:1.3;margin-bottom:8px;transition:color .2s}
#bl .ca:hover h3{color:var(--g)}
#bl .ca p{font-size:.85rem;color:var(--m);line-height:1.6;margin-bottom:14px}
#bl .ca .ft{display:flex;align-items:center;justify-content:space-between;font-size:.75rem;color:var(--m)}
#bl .ca .ft span{display:flex;gap:6px}
#bl .ca .ft span i{background:rgba(255,255,255,.05);padding:3px 10px;border-radius:99px;border:1px solid var(--bd);font-size:.65rem;text-transform:uppercase;letter-spacing:.5px}

/* FAQ */
#fq .sp{display:grid;grid-template-columns:1fr 1.5fr;gap:60px;align-items:start}
#fq .ls{display:flex;flex-direction:column;gap:8px}
#fq .it{background:var(--s);border:1px solid var(--bd);border-radius:12px;overflow:hidden;transition:border-color .25s}
#fq .it.o{border-color:rgba(201,162,39,.2)}
#fq .it button{width:100%;display:flex;align-items:center;justify-content:space-between;padding:16px 20px;text-align:left;font-size:.9rem;font-weight:600;color:var(--w);cursor:pointer;background:none;border:none}
#fq .it button i{width:22px;height:22px;border-radius:50%;border:1px solid rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .3s;font-style:normal;font-size:.8rem}
#fq .it.o button i{background:var(--g);border-color:var(--g);color:var(--b);transform:rotate(45deg)}
#fq .it .bd{max-height:0;overflow:hidden;transition:max-height .4s var(--tr)}
#fq .it .bd p{padding:0 20px 16px;font-size:.85rem;color:var(--m);line-height:1.7}

/* Contact */
#ct{background:var(--s)}
#ct .sp{display:grid;grid-template-columns:1fr 1.3fr;gap:60px;align-items:start}
#ct .ch{display:flex;flex-direction:column;gap:10px;margin-top:24px}
#ct .ch a{display:flex;align-items:center;gap:14px;padding:14px 18px;background:var(--s2);border:1px solid var(--bd);border-radius:12px;transition:border-color .2s,transform .2s}
#ct .ch a:hover{border-color:rgba(201,162,39,.2);transform:translateX(5px)}
#ct .ch a .ic{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
#ct .ch a .ic.wa{background:#0d2218}#ct .ch a .ic.ig{background:#1a0b1a}#ct .ch a .ic.em{background:#0d1226}
#ct .ch a .l{font-size:.6rem;color:var(--m);letter-spacing:1px;text-transform:uppercase}
#ct .ch a .v{font-size:.85rem;font-weight:600}
#ct .fm{background:var(--s2);border:1px solid var(--bd);border-radius:16px;padding:32px 28px}
#ct .fm h3{font-size:1.1rem;font-weight:700;margin-bottom:20px}
#ct .fm .rw{display:grid;grid-template-columns:1fr 1fr;gap:12px}
#ct .fm .fg{margin-bottom:14px}
